pipeline {
    agent any 

    environment {
        APP_NAME = "hari-app"
    }
    stages{
        stage('build')
          steps{
            sh 'mvn package'
              echo "building_${APP_NAME}"
        }

        stage ('test')
          steps {
            sh 'mv test'
        }

        stage ('deploy')
          steps {
            echo 'deploying the application'
          }


    }

}