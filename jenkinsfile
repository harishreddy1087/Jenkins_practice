pipeline {
    agent any

    environment{
        APP_NAME = "hari-app"
    }

    stages {
        stage('check the files'){
            steps{
                sh 'pwd'
                sh 'ls -l'
            }
        }
        stage('build'){
            steps{
                sh 'mvn package'
                echo "building the_${APP_NAME}"
            }

        }

    }
}